# PATHEW Environment Variables
# Copy this file to .env and fill in values

# Supabase (public anon key — safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (publishable key — safe for frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key

# Paystack (public key — safe for frontend)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your-key

# ============================================
# IMPORTANT: The following keys should ONLY be
# set as Supabase Edge Function secrets, NEVER
# in this file or in the frontend:
#
# - STRIPE_SECRET_KEY
# - ANTHROPIC_API_KEY  
# - SUPABASE_SERVICE_ROLE_KEY
#
# Set them via:
#   npx supabase secrets set STRIPE_SECRET_KEY=sk_live_xxx
#   npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxx
# ============================================
